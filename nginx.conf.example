# ─────────────────────────────────────────────────────────────
#  Nginx config for ZRC CRM
#
#  PHASE 1 — No domain yet (HTTP on EC2 IP)
#  ─────────────────────────────────────────
#  Use `server_name _;` (the catch-all below). Access the app at:
#    http://<EC2_PUBLIC_IP>
#
#  PHASE 2 — Once you have a domain
#  ──────────────────────────────────
#  1. Replace `server_name _;` with `server_name yourdomain.com www.yourdomain.com;`
#  2. Run Certbot: sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com
#  3. Update server/.env: FRONTEND_ORIGINS, COOKIE_DOMAIN, COOKIE_SECURE=true
#  4. Restart: pm2 restart zrccrm
#
#  Setup commands (run once):
#    sudo cp /home/ubuntu/zrccrm/nginx.conf.example /etc/nginx/sites-available/zrccrm
#    sudo ln -s /etc/nginx/sites-available/zrccrm /etc/nginx/sites-enabled/
#    sudo rm -f /etc/nginx/sites-enabled/default
#    sudo nginx -t
#    sudo systemctl reload nginx
# ─────────────────────────────────────────────────────────────

server {
    listen 80;
    # PHASE 1: catch-all (works with bare IP, no domain needed)
    server_name _;
    # PHASE 2: replace the line above with your domain:
    # server_name yourdomain.com www.yourdomain.com;

    # ── Gzip compression ──────────────────────────────────────
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        text/plain text/css text/xml
        application/json application/javascript application/xml+rss
        image/svg+xml;

    # ── React SPA (built files) ───────────────────────────────
    location / {
        root /home/ubuntu/zrccrm/client/dist;
        index index.html;
        # For React Router: always fall back to index.html
        try_files $uri $uri/ /index.html;

        # Cache static assets aggressively (Vite adds hashes to filenames)
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2|woff|ttf)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # ── Node.js API proxy ─────────────────────────────────────
    location /api/ {
        proxy_pass         http://localhost:5001;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Increase timeouts for file uploads / long requests
        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }

    # ── Socket.io (WebSocket upgrade) ─────────────────────────
    location /socket.io/ {
        proxy_pass         http://localhost:5001;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
        proxy_cache_bypass $http_upgrade;
    }
}

# ─────────────────────────────────────────────────────────────
#  NOTE (Phase 2 only):
#  Certbot will automatically add an HTTPS server block when you run:
#    sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com
#  You do NOT need to write the HTTPS block yourself.
#  After Certbot runs, it also updates the server_name line — make sure
#  you've already changed it from `_` to your actual domain first.
# ─────────────────────────────────────────────────────────────
