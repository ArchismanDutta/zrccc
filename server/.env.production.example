# ─────────────────────────────────────────────────────────────
#  ZRC CRM — Production Environment Variables
#
#  On EC2, copy this to /home/ubuntu/zrccrm/server/.env
#  and fill in real values.
#
#  NEVER commit the actual .env file to GitHub.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5001

# MongoDB Atlas connection string (already set up — copy from dev .env)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# Change BOTH secrets to long random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_RANDOM_STRING

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Your actual domain — no trailing slash
FRONTEND_ORIGINS=https://yourdomain.com

# Your actual domain (without https://) — used for cookies
COOKIE_DOMAIN=yourdomain.com

# Email (optional — if you want password reset emails to work)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=yourmail@gmail.com
MAIL_PASS=your-gmail-app-password
MAIL_FROM=ZRC CRM <yourmail@gmail.com>
MAIL_SECURE=false

# Token for password reset emails
RESET_TOKEN_SECRET=CHANGE_ME_ANOTHER_RANDOM_STRING
